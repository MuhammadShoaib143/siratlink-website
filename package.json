{
  "name": "siratlink-website",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next dev --webpack",
    "build": "NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next build --webpack",
    "start": "next start",
    "typegen": "NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next typegen",
    "typecheck": "NEXT_TEST_WASM_DIR=./node_modules/@next/swc-wasm-nodejs next typegen && tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "16.2.4",
    "@types/node": "22.13.14",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "autoprefixer": "10.4.20",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.2"
  }
}
